{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio-everton",
  "compatibility_date": "2026-03-07",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.ts",
  "preview_urls": true,
  "assets": {
    "not_found_handling": "none",
    "binding": "ASSETS"
  }
}
